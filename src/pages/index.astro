---
// Phase 1: 기존 vanilla HTML을 그대로 Astro로 이식
// style + body + script는 다음 태스크들에서 채움
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>맛있는 김 DB | Korean GIM Database</title>
  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f8f6f0;
      color: #333;
      padding: 24px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
    h1 { font-size: 2rem; color: #1a5c2a; }
    .lang-toggle {
      display: flex;
      border: 2px solid #1a5c2a;
      border-radius: 8px;
      overflow: hidden;
      flex-shrink: 0;
    }
    .lang-btn {
      padding: 6px 14px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      border: none;
      background: white;
      color: #1a5c2a;
      transition: all 0.2s;
    }
    .lang-btn.active {
      background: #1a5c2a;
      color: white;
    }
    .subtitle {
      color: #666;
      margin-bottom: 24px;
      font-size: 0.95rem;
    }
    .filters {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
      flex-wrap: wrap;
      align-items: center;
    }
    .filters select, .filters input {
      padding: 8px 12px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 0.9rem;
      background: white;
    }
    .filters label {
      font-size: 0.85rem;
      color: #555;
      font-weight: 600;
    }
    .filter-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    thead { background: #1a5c2a; color: white; }
    th {
      padding: 12px 14px;
      text-align: left;
      font-size: 0.85rem;
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }
    th:hover { background: #14752e; }
    th .sort-arrow { margin-left: 4px; opacity: 0.5; }
    th.sorted .sort-arrow { opacity: 1; }
    td {
      padding: 10px 14px;
      font-size: 0.88rem;
      border-bottom: 1px solid #eee;
      vertical-align: top;
    }
    tr:hover td { background: #f0f8f0; }
    td.name { font-weight: 600; min-width: 140px; }
    td.score { text-align: center; font-size: 1rem; }
    td.num { text-align: center; }
    td.review { font-size: 0.82rem; color: #444; max-width: 200px; }
    a.buy-link {
      display: inline-block;
      padding: 4px 10px;
      background: #1a5c2a;
      color: white;
      border-radius: 4px;
      text-decoration: none;
      font-size: 0.78rem;
    }
    a.buy-link:hover { background: #14752e; }
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .badge-재래김, .badge-Traditional { background: #e8f5e9; color: #2e7d32; }
    .badge-돌김, .badge-Stone { background: #e3f2fd; color: #1565c0; }
    .badge-파래김, .badge-Green { background: #f3e5f5; color: #7b1fa2; }
    .badge-조미김, .badge-Seasoned { background: #fff3e0; color: #e65100; }
    .badge-무조미김, .badge-Unseasoned { background: #efebe9; color: #4e342e; }
    .empty { color: #bbb; font-style: italic; }
    .count { font-size: 0.85rem; color: #888; margin-bottom: 12px; }
    .loading { text-align: center; padding: 40px; color: #888; }
    @media (max-width: 768px) {
      body { padding: 12px; }
      .filters { flex-direction: column; }
      table { font-size: 0.8rem; display: block; overflow-x: auto; }
      .header { flex-direction: column; gap: 12px; }
    }
  </style>
</head>
<body>
  <!-- Task 4에서 body markup 추가 -->
  <p>placeholder</p>
</body>
</html>
