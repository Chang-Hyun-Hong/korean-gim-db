---
// Phase 1: 기존 vanilla HTML을 그대로 Astro로 이식
// style + body + script는 다음 태스크들에서 채움
---
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>맛있는 김 DB | Korean GIM Database</title>
  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #f8f6f0;
      color: #333;
      padding: 24px;
      max-width: 1200px;
      margin: 0 auto;
    }
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
    h1 { font-size: 2rem; color: #1a5c2a; }
    .lang-toggle {
      display: flex;
      border: 2px solid #1a5c2a;
      border-radius: 8px;
      overflow: hidden;
      flex-shrink: 0;
    }
    .lang-btn {
      padding: 6px 14px;
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      border: none;
      background: white;
      color: #1a5c2a;
      transition: all 0.2s;
    }
    .lang-btn.active {
      background: #1a5c2a;
      color: white;
    }
    .subtitle {
      color: #666;
      margin-bottom: 24px;
      font-size: 0.95rem;
    }
    .filters {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
      flex-wrap: wrap;
      align-items: center;
    }
    .filters select, .filters input {
      padding: 8px 12px;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-size: 0.9rem;
      background: white;
    }
    .filters label {
      font-size: 0.85rem;
      color: #555;
      font-weight: 600;
    }
    .filter-group {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    thead { background: #1a5c2a; color: white; }
    th {
      padding: 12px 14px;
      text-align: left;
      font-size: 0.85rem;
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }
    th:hover { background: #14752e; }
    th .sort-arrow { margin-left: 4px; opacity: 0.5; }
    th.sorted .sort-arrow { opacity: 1; }
    td {
      padding: 10px 14px;
      font-size: 0.88rem;
      border-bottom: 1px solid #eee;
      vertical-align: top;
    }
    tr:hover td { background: #f0f8f0; }
    td.name { font-weight: 600; min-width: 140px; }
    td.score { text-align: center; font-size: 1rem; }
    td.num { text-align: center; }
    td.review { font-size: 0.82rem; color: #444; max-width: 200px; }
    a.buy-link {
      display: inline-block;
      padding: 4px 10px;
      background: #1a5c2a;
      color: white;
      border-radius: 4px;
      text-decoration: none;
      font-size: 0.78rem;
    }
    a.buy-link:hover { background: #14752e; }
    .badge {
      display: inline-block;
      padding: 2px 8px;
      border-radius: 10px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .badge-재래김, .badge-Traditional { background: #e8f5e9; color: #2e7d32; }
    .badge-돌김, .badge-Stone { background: #e3f2fd; color: #1565c0; }
    .badge-파래김, .badge-Green { background: #f3e5f5; color: #7b1fa2; }
    .badge-조미김, .badge-Seasoned { background: #fff3e0; color: #e65100; }
    .badge-무조미김, .badge-Unseasoned { background: #efebe9; color: #4e342e; }
    .empty { color: #bbb; font-style: italic; }
    .count { font-size: 0.85rem; color: #888; margin-bottom: 12px; }
    .loading { text-align: center; padding: 40px; color: #888; }
    @media (max-width: 768px) {
      body { padding: 12px; }
      .filters { flex-direction: column; }
      table { font-size: 0.8rem; display: block; overflow-x: auto; }
      .header { flex-direction: column; gap: 12px; }
    }
  </style>
</head>
<body>
  <div class="header">
    <h1 id="title">맛있는 김 DB</h1>
    <div class="lang-toggle">
      <button class="lang-btn active" data-lang="ko">한국어</button>
      <button class="lang-btn" data-lang="en">English</button>
    </div>
  </div>
  <p class="subtitle" id="subtitle">김 리뷰 데이터베이스 — 기름진 정도, 짠 정도, 총점으로 나에게 맞는 김 찾기</p>

  <div class="filters">
    <div class="filter-group">
      <label id="labelType">김 종류</label>
      <select id="filterType"></select>
    </div>
    <div class="filter-group">
      <label id="labelCook">조리상태</label>
      <select id="filterCook"></select>
    </div>
    <div class="filter-group">
      <label id="labelSearch">검색</label>
      <input type="text" id="searchInput">
    </div>
  </div>

  <p class="count"><span id="count">0</span><span id="countLabel">개 결과</span></p>

  <table>
    <thead>
      <tr id="theadRow">
        <th data-key="name"><span class="col-label">이름</span> <span class="sort-arrow">↕</span></th>
        <th data-key="type"><span class="col-label">김 종류</span> <span class="sort-arrow">↕</span></th>
        <th data-key="cook"><span class="col-label">조리</span> <span class="sort-arrow">↕</span></th>
        <th data-key="oil"><span class="col-label">기름</span> <span class="sort-arrow">↕</span></th>
        <th data-key="salt"><span class="col-label">짠맛</span> <span class="sort-arrow">↕</span></th>
        <th data-key="score"><span class="col-label">총점</span> <span class="sort-arrow">↕</span></th>
        <th data-key="review"><span class="col-label">한줄평</span></th>
        <th data-key="price"><span class="col-label">가격</span> <span class="sort-arrow">↕</span></th>
        <th><span class="col-label">링크</span></th>
      </tr>
    </thead>
    <tbody id="tbody">
      <tr><td colspan="9" class="loading">Loading...</td></tr>
    </tbody>
  </table>

  <!-- Task 5-6에서 script 추가 -->
</body>
</html>
